# Plume — variables d'environnement (exemple, AUCUN secret réel ici)
# Copier en `.env.local` (gitignored) et renseigner. Repo PUBLIC : ne jamais committer de secret.

# --- Base de données : Turso / libSQL ---
# url libSQL (ex. libsql://<db>.turso.io) ; en local : file:./local.db
TURSO_DATABASE_URL=
TURSO_AUTH_TOKEN=

# --- Auth.js v5 (Google) ---
# `openssl rand -base64 32`
AUTH_SECRET=
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=

# --- IA : SDK Anthropic (serveur uniquement, jamais NEXT_PUBLIC_*) ---
ANTHROPIC_API_KEY=

# --- Web Push / VAPID (Epic 6, différé) ---
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:contact@example.com

# --- Cron (relances push, Epic 6, différé) ---
CRON_SECRET=
