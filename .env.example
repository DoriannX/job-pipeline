# =========================================================================== #
#  CONFIGURATION — copier ce fichier en `.env` et remplir. NE PAS committer .env
# =========================================================================== #

# --- Ingestion e-mail (SOURCE PRINCIPALE — alertes job reçues par mail) ------
# Adresse Gmail qui reçoit les alertes.
IMAP_USER=
# App Password Google (PAS le mot de passe du compte). Exige 2FA + IMAP activés.
# Compte Google → Sécurité → Mots de passe d'application. Voir README.
IMAP_APP_PASSWORD=
# Mapping label Gmail → catégorie : "label:categorie,label2:categorie2".
# Crée d'abord des filtres Gmail qui rangent chaque alerte dans ces labels.
EMAIL_LABELS=jobs/alternance:alternance,jobs/cdi-fr:cdi,jobs/cdi-eu:cdi
# Optionnel : serveur/fenêtre IMAP.
# IMAP_HOST=imap.gmail.com
# IMAP_PORT=993
# EMAIL_LOOKBACK_DAYS=7

# --- Envoi du digest par e-mail (mode cloud — PC éteint) ---------------------
# Active l'envoi (mets "true" en cloud ; laisse vide/false en local).
SEND_EMAIL=false
# Destinataire (par défaut = IMAP_USER, soit toi-même).
# MAIL_TO=theodor.xav@gmail.com
# Réutilise l'App Password Gmail (SMTP SSL). Réglages avancés optionnels :
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=465

# --- Adzuna (complément API officiel — Couche 2bis) --------------------------
# Compte développeur Adzuna → app_id + app_key. Voir README.
ADZUNA_APP_ID=
ADZUNA_APP_KEY=
# Pays interrogés (codes Adzuna : fr, gb, ie, nl, de...). FR + Europe anglophone.
# ADZUNA_PAYS=fr,ie,nl,gb

# --- France Travail (OPTIONNEL / dormant — laisser vide si pas de compte) ----
FT_CLIENT_ID=
FT_CLIENT_SECRET=
# FT_SCOPE=api_offresdemploiv2 o2dsoffre
# NATURE_CONTRATS_ALTERNANCE=

# --- Optionnel : filtres France Travail (si activé) --------------------------
# MOTS_CLES=développeur,développement,logiciel,web,backend,frontend,fullstack
# DEPARTEMENT=33
# TYPE_CONTRATS=CDI

# --- Optionnel : chemin de la base SQLite ------------------------------------
# DB_PATH=data/offers.db
